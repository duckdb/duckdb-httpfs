# name: test/sql/secrets/create_secret_oss.test
# description: Test the s3_compatible_url_schemes setting (using oss:// as an example scheme)
# group: [secrets]

statement ok
PRAGMA enable_verification;

require httpfs

statement ok
set secret_directory='__TEST_DIR__/create_secret_oss'

# Without the setting, oss:// urls are not recognized
statement error
FROM 'oss://test-bucket/test.csv'
----
<REGEX>:.*(No such file or directory|No files found).*

# Register oss:// as an S3-compatible scheme
statement ok
SET s3_compatible_url_schemes='oss';

# The default scope of a new S3 secret now includes oss://
statement ok
CREATE SECRET (
    TYPE S3,
    KEY_ID 'my_key',
    SECRET 'my_secret',
    ENDPOINT 'oss-cn-hangzhou.aliyuncs.com'
)

query IIII
SELECT name, type, provider, scope FROM duckdb_secrets();
----
__default_s3	s3	config	['s3://', 's3n://', 's3a://', 'oss://']

# oss:// urls are now routed to the S3 filesystem: the request is attempted
# (and fails with an HTTP error), rather than failing with 'file not found'
statement error
FROM 'oss://test-bucket/test.csv'
----
<REGEX>:.*HTTP Error.*

# oss:// urls without a bucket are rejected by the S3 url parser
statement error
FROM 'oss:///test.csv'
----
<REGEX>:.*URL needs to contain a bucket name.*

# The setting accepts schemes with or without the :// suffix, and multiple schemes
statement ok
SET s3_compatible_url_schemes='oss://, cos';

statement ok
CREATE SECRET multi_scheme (
    TYPE S3,
    KEY_ID 'my_key',
    SECRET 'my_secret'
)

query I
SELECT scope FROM duckdb_secrets() WHERE name = 'multi_scheme';
----
['s3://', 's3n://', 's3a://', 'oss://', 'cos://']

# The setting is global-only: session-level SET is rejected
statement error
SET SESSION s3_compatible_url_schemes='oss';
----
<REGEX>:.*can only be set globally.*

# Schemes of built-in filesystems cannot be hijacked
statement error
SET s3_compatible_url_schemes='https';
----
<REGEX>:.*already handled by a built-in filesystem.*

# RESET clears the registered schemes
statement ok
SET s3_compatible_url_schemes='oss';

statement ok
RESET s3_compatible_url_schemes;

statement error
FROM 'oss://test-bucket/test.csv'
----
<REGEX>:.*(No such file or directory|No files found).*

# Clearing the setting restores the default behavior for new urls
statement ok
SET s3_compatible_url_schemes='';

statement error
FROM 'oss://test-bucket/test.csv'
----
<REGEX>:.*(No such file or directory|No files found).*
