1	0	1	0	0
13	0	13	0	0
13	0	13	0	0
13	0	13	0	0
13	0	13	0	0
1	0	1	0	0
1	0	1	0	0
13	0	13	0	0
13	0	13	0	0
36	0	36	0	0
36	0	36	0	0
1	0	1	0	0
1	0	1	0	0
7	0	7	0	0
7	0	7	0	0
1	0	1	0	0
1	0	1	0	0
